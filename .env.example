# ============================================
# API Keys for S5 AI Variant Generation
# ============================================

# ServerChan (用于进度汇报)
# https://sct.ftqq.com/
SERVERCHAN_SENDKEY=your_sendkey_here

# DeepSeek API
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Aliyun (Qwen)
# https://dashscope.aliyun.com/
ALIYUN_API_KEY=your_aliyun_key_here
ALIYUN_QWEN35_FLASH_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_QWEN3_MAX_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Moonshot (Kimi)
# https://platform.moonshot.cn/
MOONSHOT_API_KEY=your_moonshot_key_here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# Zhipu (可选)
# https://open.bigmodel.cn/
# ZHIPU_API_KEY=your_zhipu_key_here
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ============================================
# Model Paths (S6)
# ============================================

# BERT Model Path
# BERT_MODEL_PATH=/path/to/your/bert/model

# ============================================
# Project Paths (可选)
# ============================================

# PROJECT_ROOT=/path/to/project
